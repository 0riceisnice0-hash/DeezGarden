---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Hero from '../../components/Hero.astro';
import TrustBadges from '../../components/TrustBadges.astro';
import CallToAction from '../../components/CallToAction.astro';
import HeroCTA from '../../components/HeroCTA.astro';
import SlideOutQuoteForm from '../../components/SlideOutQuoteForm.astro';
import { siteConfig } from '../../config';
---

<BaseLayout 
  title="Garden Clearance Northampton | Overgrown Garden & Vegetation Clearance"
  description="Professional garden clearance in Northampton & Northamptonshire. Overgrown garden clearance, vegetation clearance, site clearance & garden waste removal. Licensed waste carrier. Free quotes - call 07305 195098."
>
  <Header slot="header" />
  
  <SlideOutQuoteForm />
  
  <Hero 
    title="Garden Clearance & Overgrown Gardens"
    subtitle="Vegetation clearance and garden waste removal across Northamptonshire"
    heroImage="hero.jpg"
    showCTA={true}
    showQuoteButton={true}
  />
  
  <TrustBadges />
  
  <!-- Introduction Section -->
  <section class="py-6 md:py-16 bg-bg-sage border-b-2 border-fresh-green/20">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <div class="bg-white rounded-2xl shadow-lg p-6 md:p-10 border-2 border-fresh-green/20">
          <h2 class="text-xl md:text-3xl font-extrabold text-deep-green mb-4 md:mb-6 tracking-tight text-center">Garden Clearance in Northampton & Northamptonshire</h2>
          <p class="text-sm md:text-lg text-gray-700 leading-relaxed mb-4">
            Got an overgrown garden that's been neglected for years? Need vegetation clearance on a new plot before building work can start? {siteConfig.name} provides professional garden clearance, overgrown garden clearance, and vegetation clearance services across Northampton, Rushden, Brackley and the surrounding Northamptonshire area.
          </p>
          <p class="text-sm md:text-lg text-gray-700 leading-relaxed">
            As a licensed waste carrier, all green waste, rubbish, and vegetation is disposed of legally and responsibly. We leave your outdoor space ready for its next chapter — whether that's a fresh landscaping project, a tidy-up, or simply enjoying an accessible, clear garden again.
          </p>
          <div class="flex items-center justify-center gap-4 mt-6 p-4 bg-fresh-green/10 rounded-lg">
            <span class="text-2xl md:text-3xl">📋</span>
            <div>
              <p class="font-bold text-deep-green text-sm md:text-base">Licensed Waste Carrier</p>
              <p class="text-xs md:text-sm text-gray-600">All waste disposed of legally and responsibly</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Clearance Services Grid -->
  <section class="py-6 md:py-16 bg-bg-light border-b-2 border-fresh-green/20">
    <div class="container mx-auto px-4">
      <div class="max-w-6xl mx-auto">
        <h2 class="text-lg md:text-2xl font-extrabold text-center mb-6 md:mb-10 tracking-tight">Our Garden Clearance Services</h2>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-8">
          <!-- Overgrown Garden Clearance Card -->
          <div class="bg-white rounded-xl shadow-lg p-6 md:p-8 border-l-4 border-fresh-green hover:shadow-xl transition">
            <div class="flex items-center mb-4">
              <div class="w-12 h-12 md:w-14 md:h-14 bg-fresh-green/10 rounded-full flex items-center justify-center mr-4">
                <span class="text-2xl md:text-3xl">🌿</span>
              </div>
              <h3 class="text-lg md:text-xl font-bold text-deep-green">Overgrown Garden Clearance</h3>
            </div>
            <p class="text-gray-600 text-sm md:text-base mb-4">Reclaim your garden from years of overgrowth. We clear it completely, ready for a fresh start.</p>
            <ul class="space-y-2 text-sm md:text-base">
              <li class="flex items-start"><span class="text-fresh-green mr-2 font-bold">✓</span>Overgrown shrubs and brambles</li>
              <li class="flex items-start"><span class="text-fresh-green mr-2 font-bold">✓</span>Unwanted trees and stumps</li>
              <li class="flex items-start"><span class="text-fresh-green mr-2 font-bold">✓</span>Weeds and vegetation removal</li>
              <li class="flex items-start"><span class="text-fresh-green mr-2 font-bold">✓</span>Garden rubbish and waste cleared</li>
            </ul>
          </div>
          
          <!-- Vegetation & Site Clearance Card -->
          <div class="bg-white rounded-xl shadow-lg p-6 md:p-8 border-l-4 border-deep-green hover:shadow-xl transition">
            <div class="flex items-center mb-4">
              <div class="w-12 h-12 md:w-14 md:h-14 bg-deep-green/10 rounded-full flex items-center justify-center mr-4">
                <span class="text-2xl md:text-3xl">🏗️</span>
              </div>
              <h3 class="text-lg md:text-xl font-bold text-deep-green">Vegetation & Site Clearance</h3>
            </div>
            <p class="text-gray-600 text-sm md:text-base mb-4">Pre-build or pre-development site clearance, stripping vegetation and preparing ground.</p>
            <ul class="space-y-2 text-sm md:text-base">
              <li class="flex items-start"><span class="text-fresh-green mr-2 font-bold">✓</span>Full vegetation strip and clear</li>
              <li class="flex items-start"><span class="text-fresh-green mr-2 font-bold">✓</span>Site clearance for building projects</li>
              <li class="flex items-start"><span class="text-fresh-green mr-2 font-bold">✓</span>Commercial garden clearance</li>
              <li class="flex items-start"><span class="text-fresh-green mr-2 font-bold">✓</span>All waste removed and disposed of</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <!-- What We Clear -->
  <section class="py-6 md:py-16 bg-white border-b-2 border-fresh-green/20">
    <div class="container mx-auto px-4">
      <div class="max-w-6xl mx-auto">
        <h2 class="text-lg md:text-2xl font-extrabold text-center mb-6 md:mb-10 tracking-tight">What We Clear</h2>
        
        <div class="grid grid-cols-2 md:grid-cols-3 gap-3 md:gap-6">
          <div class="bg-bg-sage rounded-lg p-4 md:p-6 text-center hover:shadow-md transition">
            <span class="text-2xl md:text-3xl mb-2 block">🌱</span>
            <h4 class="font-bold text-sm md:text-base text-deep-green">Overgrown Vegetation</h4>
            <p class="text-xs md:text-sm text-gray-600 mt-1">Brambles, nettles, weeds</p>
          </div>
          <div class="bg-bg-sage rounded-lg p-4 md:p-6 text-center hover:shadow-md transition">
            <span class="text-2xl md:text-3xl mb-2 block">🌳</span>
            <h4 class="font-bold text-sm md:text-base text-deep-green">Trees & Shrubs</h4>
            <p class="text-xs md:text-sm text-gray-600 mt-1">Cutting, removal, stump grinding</p>
          </div>
          <div class="bg-bg-sage rounded-lg p-4 md:p-6 text-center hover:shadow-md transition">
            <span class="text-2xl md:text-3xl mb-2 block">🍂</span>
            <h4 class="font-bold text-sm md:text-base text-deep-green">Garden Waste</h4>
            <p class="text-xs md:text-sm text-gray-600 mt-1">Grass, leaves, cuttings, soil</p>
          </div>
          <div class="bg-bg-sage rounded-lg p-4 md:p-6 text-center hover:shadow-md transition">
            <span class="text-2xl md:text-3xl mb-2 block">📦</span>
            <h4 class="font-bold text-sm md:text-base text-deep-green">Rubbish & Junk</h4>
            <p class="text-xs md:text-sm text-gray-600 mt-1">Old furniture, debris, waste</p>
          </div>
          <div class="bg-bg-sage rounded-lg p-4 md:p-6 text-center hover:shadow-md transition">
            <span class="text-2xl md:text-3xl mb-2 block">🏚️</span>
            <h4 class="font-bold text-sm md:text-base text-deep-green">Derelict Gardens</h4>
            <p class="text-xs md:text-sm text-gray-600 mt-1">Full clear of neglected plots</p>
          </div>
          <div class="bg-bg-sage rounded-lg p-4 md:p-6 text-center hover:shadow-md transition">
            <span class="text-2xl md:text-3xl mb-2 block">🏢</span>
            <h4 class="font-bold text-sm md:text-base text-deep-green">Commercial Sites</h4>
            <p class="text-xs md:text-sm text-gray-600 mt-1">Business & development plots</p>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <CallToAction showDualCTA={true} />
  
  <!-- Why Choose Us -->
  <section class="py-6 md:py-16 bg-bg-sage border-b-2 border-fresh-green/20">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-lg md:text-2xl font-extrabold text-center mb-6 md:mb-10 tracking-tight">Why Choose {siteConfig.name} for Garden Clearance?</h2>
        
        <div class="bg-white rounded-2xl shadow-lg p-6 md:p-10 border-2 border-fresh-green/20">
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6 mb-6 md:mb-8">
            <div class="text-center">
              <div class="w-12 h-12 md:w-16 md:h-16 bg-fresh-green/10 rounded-full flex items-center justify-center mx-auto mb-2 md:mb-3">
                <span class="text-xl md:text-2xl">📋</span>
              </div>
              <h4 class="font-bold text-sm md:text-base text-deep-green">Licensed Carrier</h4>
            </div>
            <div class="text-center">
              <div class="w-12 h-12 md:w-16 md:h-16 bg-fresh-green/10 rounded-full flex items-center justify-center mx-auto mb-2 md:mb-3">
                <span class="text-xl md:text-2xl">🛡️</span>
              </div>
              <h4 class="font-bold text-sm md:text-base text-deep-green">Fully Insured</h4>
            </div>
            <div class="text-center">
              <div class="w-12 h-12 md:w-16 md:h-16 bg-fresh-green/10 rounded-full flex items-center justify-center mx-auto mb-2 md:mb-3">
                <span class="text-xl md:text-2xl">♻️</span>
              </div>
              <h4 class="font-bold text-sm md:text-base text-deep-green">Eco-Friendly</h4>
            </div>
            <div class="text-center">
              <div class="w-12 h-12 md:w-16 md:h-16 bg-fresh-green/10 rounded-full flex items-center justify-center mx-auto mb-2 md:mb-3">
                <span class="text-xl md:text-2xl">💰</span>
              </div>
              <h4 class="font-bold text-sm md:text-base text-deep-green">Fair Pricing</h4>
            </div>
          </div>
          
          <p class="text-sm md:text-lg text-gray-700 leading-relaxed text-center">
            We cover Northampton, Rushden, Brackley, Wellingborough, Kettering and the whole of Northamptonshire. All garden waste and vegetation is taken away and disposed of responsibly at licensed facilities — no fly-tipping, no fuss.
          </p>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Areas We Cover -->
  <section class="py-6 md:py-16 bg-white border-b-2 border-fresh-green/20">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-lg md:text-2xl font-bold mb-4 md:mb-8 text-center">Garden Clearance Across Northamptonshire</h2>
        <p class="text-center text-sm md:text-base mb-4 md:mb-8">
          We provide professional garden clearance and vegetation clearance services throughout:
        </p>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4 text-center">
          {[...siteConfig.primaryAreas, ...siteConfig.secondaryAreas.slice(0, 3)].map(area => (
            <a 
              href={`/areas/${area.toLowerCase().replace(/ /g, '-')}/`}
              class="bg-bg-light p-3 md:p-4 rounded-lg hover:bg-fresh-green hover:text-white transition font-semibold text-sm md:text-base"
            >
              {area}
            </a>
          ))}
        </div>
        <div class="text-center mt-4 md:mt-6">
          <a href="/areas/" class="text-fresh-green font-semibold hover:text-deep-green text-sm md:text-base">
            View all areas we cover →
          </a>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Related Services -->
  <section class="py-6 md:py-12 bg-bg-light border-b-2 border-fresh-green/20">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto text-center">
        <h3 class="text-base md:text-xl font-bold mb-4 md:mb-6">Related Services You May Need</h3>
        <div class="flex flex-wrap justify-center gap-3 md:gap-4">
          <a href="/services/garden-maintenance/" class="bg-white px-4 py-2 md:px-6 md:py-3 rounded-lg font-semibold text-sm md:text-base text-deep-green hover:bg-fresh-green hover:text-white transition shadow-md">
            Garden Maintenance →
          </a>
          <a href="/services/clearance-removals/" class="bg-white px-4 py-2 md:px-6 md:py-3 rounded-lg font-semibold text-sm md:text-base text-deep-green hover:bg-fresh-green hover:text-white transition shadow-md">
            Rubbish Clearance →
          </a>
          <a href="/services/landscaping/" class="bg-white px-4 py-2 md:px-6 md:py-3 rounded-lg font-semibold text-sm md:text-base text-deep-green hover:bg-fresh-green hover:text-white transition shadow-md">
            Landscaping →
          </a>
        </div>
      </div>
    </div>
  </section>
  
  <HeroCTA />
  
  <Footer slot="footer" />
</BaseLayout>

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Garden Clearance and Vegetation Clearance",
  "name": "Garden Clearance & Overgrown Garden Clearance Northampton",
  "url": `${siteConfig.baseUrl}/services/garden-clearance/`,
  "provider": {
    "@type": "LocalBusiness",
    "name": siteConfig.name,
    "telephone": siteConfig.phone,
    "email": siteConfig.email,
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Northampton",
      "addressRegion": "Northamptonshire",
      "addressCountry": "GB"
    }
  },
  "areaServed": [...siteConfig.primaryAreas, ...siteConfig.secondaryAreas].map(area => ({
    "@type": "City",
    "name": area
  })),
  "description": "Professional garden clearance, overgrown garden clearance, vegetation clearance and site clearance in Northampton and Northamptonshire. Licensed waste carrier — all green waste removed responsibly.",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Garden Clearance Services",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Overgrown Garden Clearance" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Vegetation Clearance" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Site Clearance" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Commercial Garden Clearance" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Garden Waste Removal" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Derelict Garden Clearance" } }
    ]
  }
})} />
