---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Hero from '../../components/Hero.astro';
import TrustBadges from '../../components/TrustBadges.astro';
import CallToAction from '../../components/CallToAction.astro';
import HeroCTA from '../../components/HeroCTA.astro';
import { siteConfig, services } from '../../config';

const areaName = "Rushden";
const nearbyAreas = ["Wellingborough", "Kettering", "Northampton", "Bedford"];
---

<BaseLayout 
  title={`Garden Clearance ${areaName} | Overgrown Garden Clearance & Garden Services`}
  description={`Professional garden clearance, overgrown garden clearance & garden maintenance in ${areaName}, Northamptonshire. Fully insured, licensed waste carrier. Free quotes - call 07305 195098.`}
>
  <Header slot="header" />
  
  <Hero 
    title={`Garden Clearance & Services in ${areaName}`}
    location={`${areaName}, Northamptonshire`}
    subtitle="Garden clearance, overgrown garden clearance & maintenance"
    heroImage="hero.jpg"
  />
  
  <TrustBadges />
  
  <!-- Introduction Section -->
  <section class="py-4 md:py-16 bg-bg-light">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-xl md:text-3xl font-bold mb-3 md:mb-6">Garden Clearance in {areaName}</h2>
        <p class="text-sm md:text-lg mb-2 md:mb-4">
          {siteConfig.name} provides professional garden clearance, overgrown garden clearance, and garden maintenance services throughout {areaName} and the surrounding Northamptonshire area. Whether you need an overgrown garden cleared, garden rubbish removed, or an ongoing maintenance programme set up, our team is here to help {areaName} residents and businesses.
        </p>
        <p class="text-sm md:text-lg">
          As a licensed waste carrier, all garden waste and rubbish is disposed of legally and responsibly. We take pride in leaving every garden in {areaName} cleaner and tidier than we found it.
        </p>
      </div>
    </div>
  </section>

  <!-- Rushden-Specific Services Section -->
  <section class="py-4 md:py-16 bg-bg-sage border-b-2 border-fresh-green/20">
    <div class="container mx-auto px-4">
      <div class="max-w-6xl mx-auto">
        <h2 class="text-lg md:text-2xl font-extrabold text-center mb-6 md:mb-10 tracking-tight">Popular Services in {areaName}</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6">
          <div class="bg-white rounded-xl shadow-lg p-6 border-l-4 border-fresh-green">
            <h3 class="text-base md:text-lg font-bold text-deep-green mb-2">Garden Clearance {areaName}</h3>
            <p class="text-sm md:text-base text-gray-700 mb-3">Overgrown garden clearance in {areaName} — we clear brambles, weeds, shrubs, and garden waste. Licensed waste carrier, all arisings removed responsibly.</p>
            <a href="/services/garden-clearance/" class="text-fresh-green font-semibold hover:text-deep-green text-sm">Learn more →</a>
          </div>
          <div class="bg-white rounded-xl shadow-lg p-6 border-l-4 border-deep-green">
            <h3 class="text-base md:text-lg font-bold text-deep-green mb-2">Garden Rubbish Removal {areaName}</h3>
            <p class="text-sm md:text-base text-gray-700 mb-3">Garden rubbish clearance and waste removal in {areaName}. We collect and dispose of garden waste, old furniture, and general rubbish from your property.</p>
            <a href="/services/clearance-removals/" class="text-fresh-green font-semibold hover:text-deep-green text-sm">Learn more →</a>
          </div>
          <div class="bg-white rounded-xl shadow-lg p-6 border-l-4 border-fresh-green">
            <h3 class="text-base md:text-lg font-bold text-deep-green mb-2">Garden Maintenance {areaName}</h3>
            <p class="text-sm md:text-base text-gray-700 mb-3">Regular garden maintenance in {areaName} — lawn mowing, hedge trimming, weeding, and seasonal tidy-ups to keep your garden looking its best.</p>
            <a href="/services/garden-maintenance/" class="text-fresh-green font-semibold hover:text-deep-green text-sm">Learn more →</a>
          </div>
          <div class="bg-white rounded-xl shadow-lg p-6 border-l-4 border-deep-green">
            <h3 class="text-base md:text-lg font-bold text-deep-green mb-2">Landscaping {areaName}</h3>
            <p class="text-sm md:text-base text-gray-700 mb-3">Garden landscaping and redesign in {areaName} — patios, turfing, fencing, planting and complete garden makeovers. Transform your outdoor space.</p>
            <a href="/services/landscaping/" class="text-fresh-green font-semibold hover:text-deep-green text-sm">Learn more →</a>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Services Section -->
  <section class="py-4 md:py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-6xl mx-auto">
        <h3 class="text-lg md:text-2xl font-bold mb-4 md:mb-8 text-center">Our Services in {areaName}</h3>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-6">
          {services.map((service, index) => {
            const images = [
              "/assets/images/before and after lawn 1.jpg",
              "/assets/images/rubbish removal 1.jpg",
              "/assets/images/van scrap png.png"
            ];
            return (
              <div class="bg-bg-light rounded-xl overflow-hidden shadow-md hover:shadow-lg transition flex flex-col h-full">
                <div class="h-32 md:h-48 overflow-hidden flex-shrink-0">
                  <img 
                    src={images[index]} 
                    alt={service.title}
                    class="w-full h-full object-cover"
                  />
                </div>
                <div class="p-4 md:p-6 flex flex-col flex-grow">
                  <h4 class="font-bold text-base md:text-lg mb-2 text-deep-green min-h-[2.5rem] md:min-h-[3rem]">{service.title}</h4>
                  <p class="text-xs md:text-sm text-gray-700 mb-3 flex-grow">{service.description}</p>
                  <a 
                    href={`/services/${service.slug}/`}
                    class="inline-block bg-fresh-green text-white px-4 py-2 rounded-lg font-semibold text-sm hover:bg-deep-green transition w-full text-center mt-auto"
                  >
                    Learn More
                  </a>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </div>
  </section>
  
  <CallToAction />
  
  <!-- Why Choose Us Section -->
  <section class="py-4 md:py-16 bg-gradient-to-b from-white to-light-green/5">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-lg md:text-3xl font-bold mb-4 md:mb-8 text-center">Why Choose {siteConfig.name} in {areaName}?</h2>
        
        <p class="text-sm md:text-lg text-center mb-4 md:mb-8">
          We're proud to extend our services to {areaName}, offering the same high standards we provide in Northampton and throughout the region.
        </p>
        
        <div class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-6">
          <div class="bg-white rounded-lg p-3 md:p-6 shadow-sm border border-gray-100 text-center">
            <div class="text-2xl md:text-3xl mb-2">🛡️</div>
            <h4 class="font-bold text-sm md:text-base text-deep-green mb-1">Fully Insured</h4>
            <p class="text-xs md:text-sm text-gray-600">Complete peace of mind</p>
          </div>
          <div class="bg-white rounded-lg p-3 md:p-6 shadow-sm border border-gray-100 text-center">
            <div class="text-2xl md:text-3xl mb-2">📋</div>
            <h4 class="font-bold text-sm md:text-base text-deep-green mb-1">Licensed Carrier</h4>
            <p class="text-xs md:text-sm text-gray-600">Legal waste disposal</p>
          </div>
          <div class="bg-white rounded-lg p-3 md:p-6 shadow-sm border border-gray-100 text-center">
            <div class="text-2xl md:text-3xl mb-2">⭐</div>
            <h4 class="font-bold text-sm md:text-base text-deep-green mb-1">Professional</h4>
            <p class="text-xs md:text-sm text-gray-600">Quality workmanship</p>
          </div>
          <div class="bg-white rounded-lg p-3 md:p-6 shadow-sm border border-gray-100 text-center">
            <div class="text-2xl md:text-3xl mb-2">💰</div>
            <h4 class="font-bold text-sm md:text-base text-deep-green mb-1">Fair Pricing</h4>
            <p class="text-xs md:text-sm text-gray-600">No hidden fees</p>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <CallToAction text={`Get Your Free ${areaName} Quote`} />
  
  <!-- Nearby Areas Section -->
  <section class="py-4 md:py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-lg md:text-3xl font-bold mb-4 md:mb-6">Nearby Areas We Also Serve</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4">
          {nearbyAreas.map((nearbyArea: string) => (
            <a 
              href={`/areas/${nearbyArea.toLowerCase().replace(/ /g, '-')}/`}
              class="bg-bg-light p-3 md:p-4 rounded-lg hover:bg-fresh-green hover:text-white transition font-semibold text-sm md:text-base"
            >
              {nearbyArea}
            </a>
          ))}
        </div>
        <div class="mt-4 md:mt-6">
          <a href="/areas/" class="text-fresh-green font-semibold hover:text-deep-green text-sm md:text-base">
            View all areas →
          </a>
        </div>
      </div>
    </div>
  </section>
  
  <HeroCTA />
  
  <Footer slot="footer" />
</BaseLayout>

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": `${siteConfig.name} - ${areaName}`,
  "description": `Professional garden clearance, overgrown garden clearance, garden maintenance and landscaping in ${areaName}, Northamptonshire. Fully insured, licensed waste carrier.`,
  "url": `${siteConfig.baseUrl}/areas/${areaName.toLowerCase().replace(/ /g, '-')}/`,
  "telephone": siteConfig.phone,
  "email": siteConfig.email,
  "address": {
    "@type": "PostalAddress",
    "addressLocality": areaName,
    "addressRegion": "Northamptonshire",
    "addressCountry": "GB"
  },
  "areaServed": {
    "@type": "City",
    "name": areaName
  },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": `Services in ${areaName}`,
    "itemListElement": services.map(service => ({
      "@type": "Offer",
      "itemOffered": {
        "@type": "Service",
        "name": service.title,
        "description": service.description
      }
    }))
  },
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"],
    "opens": "08:00",
    "closes": "18:00"
  },
  "priceRange": "££"
})} />
